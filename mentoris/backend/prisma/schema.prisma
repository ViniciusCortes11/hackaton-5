generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(uuid())
  nome       String
  matricula  String   @unique
  senha      String
  curso      String
  periodo    Int
  tipo       String
  avatar     String?
  objetivos  String?
  createdAt  DateTime @default(now())

  reviewsRecebidas Review[] @relation("MentorReviews")
}

model Review {
  id         String   @id @default(uuid())
  nota       Int
  comentario String
  autor      String
  createdAt  DateTime @default(now())

  mentorId String
  mentor   User @relation("MentorReviews", fields: [mentorId], references: [id])
}
